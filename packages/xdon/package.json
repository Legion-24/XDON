{
  "name": "@legion24/xdon",
  "version": "1.0.0-beta.3",
  "description": "XDON (eXtensible Data Object Notation) — schema-ambient compact text format. 30–40% smaller than JSON for tabular data. Parser, stringifier, JSON bridge, and macro preprocessor.",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node scripts/rename-cjs.js",
    "prepublishOnly": "npm run build",
    "test": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "xdon",
    "json",
    "notation",
    "parser",
    "stringifier",
    "structured-data",
    "schema",
    "compact",
    "language-model",
    "llm-tokens"
  ],
  "author": "Legion 24",
  "license": "MIT",
  "homepage": "https://github.com/Legion-24/XDON#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Legion-24/XDON.git",
    "directory": "packages/xdon"
  },
  "bugs": {
    "url": "https://github.com/Legion-24/XDON/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@types/jest": "^29.5.11",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
